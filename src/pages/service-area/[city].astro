---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import Neighborhoods from '../../components/Neighborhoods.astro';
import CommonIssues from '../../components/CommonIssues.astro';
import FaqSection from '../../components/FaqSection.astro';
import NearbyCities from '../../components/NearbyCities.astro';
import Reviews from '../../components/Reviews.astro';
import FinalCta from '../../components/FinalCta.astro';
import { CITIES, nearbyCities } from '../../config/cities';
import type { City } from '../../config/cities';
import { SITE, tel } from '../../config/site';
import { getHeroUrl } from '../../lib/images';
import { breadcrumb, faqPage } from '../../lib/schema';
import { cityUrl } from '../../lib/urls';

export function getStaticPaths() {
  return CITIES.map((c) => ({ params: { city: c.slug }, props: { city: c } }));
}

interface Props { city: City }
const { city } = Astro.props;
const place = `${city.name}${city.state ? ', ' + city.state : ''}`;
const near = nearbyCities(city);

// ~55–60 char title; unique, city-specific meta description.
const title = `Garage Door Repair ${place} | Same-Day Service`;
const description = `Need garage door repair in ${city.name}? Same-day spring repair, opener repair, cable replacement & new door installation across ${city.name} and the East Bay. Call ${SITE.phoneDisplay}.`;
const base = Astro.site?.href ?? 'https://example.com/';
const jsonLd = [
  breadcrumb([
    { name: 'Home', url: base },
    { name: city.name, url: new URL(cityUrl(city), base).href },
  ]),
  faqPage(city.faqs),
];
const heroUrl = await getHeroUrl(city.heroImage);
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} heroImageUrl={heroUrl}>
  <div class="container">
    <nav class="crumbs"><a href="/">Home</a><span>/</span>Service Area<span>/</span>{city.name}</nav>
  </div>

  <section class="hero hero-single" style={`--hero-img: url(${heroUrl})`}>
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-copy">
        <h1>Garage Door Repair in {place}</h1>
        <p class="lede">
          Same-day garage door repair, spring &amp; opener service, and new door installation for
          {city.name} homeowners — licensed, insured, and upfront about pricing.
        </p>
        <div class="hero-cta">
          <a class="btn btn-call btn-lg" href={tel()}>📞 Call {SITE.phoneDisplay}</a>
          <a class="btn btn-dark btn-lg" href="#quote">Get a Free Quote</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container prose" style="max-width:820px;">
      <h2>Trusted Garage Door Repair in {city.name}</h2>
      <p>{city.intro}</p>
      <p>
        Explore our <a href="/garage-door-repair/">garage door repair services</a> or call
        <a href={tel()}>{SITE.phoneDisplay}</a> for fast, local service in {city.name}.
      </p>
    </div>
  </section>

  <ServiceCards
    city={city}
    title={`Garage Door Services We Offer in ${city.name}`}
    sub={`From broken springs to new doors — full-service garage door help in ${city.name}.`}
  />

  <Neighborhoods cityName={city.name} neighborhoods={city.neighborhoods} />
  <CommonIssues cityName={city.name} issues={city.issues} />

  <section class="section section-soft">
    <div class="container" style="max-width:720px;">
      <div id="quote">
        <QuoteForm source={`city:${city.slug}`} heading={`Free Quote in ${city.name}`} />
      </div>
    </div>
  </section>

  <FaqSection faqs={city.faqs} title={`Garage Door Repair in ${city.name} — FAQs`} />
  <NearbyCities cities={near} cityName={city.name} />
  <Reviews />
  <FinalCta
    heading={`Garage door help in ${city.name}, today.`}
    sub={`Call now for same-day service in ${city.name}, or request a free quote.`}
  />
</BaseLayout>
