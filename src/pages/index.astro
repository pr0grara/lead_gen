---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import ServiceCards from '../components/ServiceCards.astro';
import ServiceAreaMap from '../components/ServiceAreaMap.astro';
import Reviews from '../components/Reviews.astro';
import FinalCta from '../components/FinalCta.astro';
import { SITE, tel } from '../config/site';
import { getHeroUrl } from '../lib/images';

const title = 'East Bay Garage Door Repair | Same-Day Service';
const description = `Fast, reliable ${SITE.trade} and installation across the ${SITE.region}. Same-day mobile service, licensed technicians, upfront pricing. Call ${SITE.phoneDisplay}.`;
const heroUrl = await getHeroUrl();
---
<BaseLayout title={title} description={description} heroImageUrl={heroUrl}>
  <section class="hero" style={`--hero-img: url(${heroUrl})`}>
    <div class="hero-overlay"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1>{SITE.region} Garage Door</h1>
        <h1>Repair Pros</h1>
        <p class="lede">
          Broken spring, noisy opener, or a door off its track? Our licensed technicians repair and
          install every make and model — same-day mobile service with upfront pricing.
        </p>
        <div class="hero-cta">
          <a class="btn btn-call btn-lg" href={tel()}>📞 Call Now: {SITE.phoneDisplay}</a>
          <a class="btn btn-dark btn-lg" href="#quote">Get a Free Quote</a>
        </div>
        <ul class="trust-row">
          <li>✔ Same-Day Service</li>
          <li>✔ Licensed &amp; Insured</li>
          <li>✔ 5-Year Warranty</li>
        </ul>
      </div>
      <div class="hero-form" id="quote">
        <QuoteForm source="home" />
      </div>
    </div>
  </section>

  <ServiceCards />
  <ServiceAreaMap />
  <Reviews />
  <FinalCta />
</BaseLayout>
