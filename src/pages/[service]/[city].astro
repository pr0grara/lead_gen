---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import FaqSection from '../../components/FaqSection.astro';
import NearbyCities from '../../components/NearbyCities.astro';
import FinalCta from '../../components/FinalCta.astro';
import { MATRIX_SERVICES } from '../../config/services';
import type { Service } from '../../config/services';
import { CITIES, nearbyCities } from '../../config/cities';
import type { City } from '../../config/cities';
import { SITE, tel } from '../../config/site';
import { getHeroUrl } from '../../lib/images';
import { breadcrumb, faqPage, serviceSchema } from '../../lib/schema';
import { serviceUrl, cityServiceUrl, cityUrl } from '../../lib/urls';

export function getStaticPaths() {
  const paths = [];
  for (const service of MATRIX_SERVICES) {
    for (const city of CITIES) {
      paths.push({ params: { service: service.slug, city: city.slug }, props: { service, city } });
    }
  }
  return paths;
}

interface Props { service: Service; city: City }
const { service, city } = Astro.props;
const place = `${city.name}${city.state ? ', ' + city.state : ''}`;
const near = nearbyCities(city);
const hoods = city.neighborhoods.slice(0, 3).join(', ');

const title = `${service.name} in ${place} | Same-Day`;
const description = `${service.name} in ${city.name}, ${city.state ?? 'CA'} — same-day service with upfront pricing from licensed local techs. Serving ${city.name} and the nearby East Bay. Call ${SITE.phoneDisplay}.`;

// Localized FAQ: the city's same-day question + this service's FAQs.
const comboFaqs = [city.faqs[0], ...service.faqs].filter(Boolean);

const base = Astro.site?.href ?? 'https://example.com/';
const jsonLd = [
  breadcrumb([
    { name: 'Home', url: base },
    { name: service.short, url: new URL(serviceUrl(service), base).href },
    { name: city.name, url: new URL(cityServiceUrl(service, city), base).href },
  ]),
  serviceSchema({ name: `${service.name} in ${city.name}`, description: service.description, areaName: place }),
  faqPage(comboFaqs),
];
const heroUrl = await getHeroUrl(city.heroImage);
// Per-city photo override (real local job photo), falling back to the service default.
const servicePhoto = city.serviceImages?.[service.slug] ?? service.image;
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} heroImageUrl={heroUrl}>
  <div class="container">
    <nav class="crumbs">
      <a href="/">Home</a><span>/</span><a href={serviceUrl(service)}>{service.short}</a><span>/</span>{city.name}
    </nav>
  </div>

  <section class="hero hero-single" style={`--hero-img: url(${heroUrl})`}>
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-copy">
        <h1>{service.name} in {city.name}</h1>
        <p class="lede">
          Fast, local {service.short.toLowerCase()} for {city.name} homeowners — same-day mobile
          service from licensed, insured technicians.
        </p>
        <div class="hero-cta">
          <a class="btn btn-call btn-lg" href={tel()}>📞 Call {SITE.phoneDisplay}</a>
          <a class="btn btn-dark btn-lg" href="#quote">Get a Free Quote</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container srow">
      <div class="srow-text prose">
        <h2>{service.short} in {city.name}, {city.state}</h2>
        <p>{service.description}</p>
        <p>
          We provide {service.short.toLowerCase()} throughout {city.name} — including {hoods} and the
          surrounding {SITE.region} — arriving fully stocked to finish most jobs in a single visit,
          with a clear, upfront quote before any work begins. Need broader help? See our
          <a href={cityUrl(city)}>garage door repair in {city.name}</a> page or our
          <a href={serviceUrl(service)}>{service.short.toLowerCase()} service</a> details.
        </p>
        <ul class="checklist">{service.points.map((p) => <li>{p}</li>)}</ul>
      </div>
      <div class="srow-photo"><Image src={servicePhoto} alt={`${service.imageAlt} in ${city.name}`} width={800} loading="lazy" /></div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container" style="max-width:720px;">
      <div id="quote">
        <QuoteForm
          source={`${service.slug}:${city.slug}`}
          heading={`Free Quote — ${service.short} in ${city.name}`}
          sub="Tell us what's going on and we'll call you right back."
        />
      </div>
    </div>
  </section>

  <FaqSection faqs={comboFaqs} title={`${service.short} in ${city.name} — FAQs`} />

  <ServiceCards
    city={city}
    title={`Other Garage Door Services in ${city.name}`}
    sub={`We handle every garage door issue in ${city.name} and nearby.`}
  />

  <NearbyCities cities={near} service={service} cityName={city.name} />

  <FinalCta
    heading={`${service.short} in ${city.name}, today.`}
    sub={`Call now for same-day ${service.short.toLowerCase()} in ${city.name}, or request a free quote.`}
  />
</BaseLayout>
