---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import CityLinks from '../../components/CityLinks.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import FaqSection from '../../components/FaqSection.astro';
import Reviews from '../../components/Reviews.astro';
import FinalCta from '../../components/FinalCta.astro';
import { SERVICES } from '../../config/services';
import type { Service } from '../../config/services';
import { SITE, tel } from '../../config/site';
import { getHeroUrl } from '../../lib/images';
import { breadcrumb, faqPage, serviceSchema } from '../../lib/schema';
import { serviceUrl } from '../../lib/urls';

export function getStaticPaths() {
  return SERVICES.map((s) => ({ params: { service: s.slug }, props: { service: s } }));
}

interface Props { service: Service }
const { service } = Astro.props;

const title = `${service.name} | ${SITE.region} Same-Day Service`;
const description = `${service.blurb} ${SITE.company} provides ${service.name.toLowerCase()} across the ${SITE.region} — licensed, insured, upfront pricing. Call ${SITE.phoneDisplay}.`;
const base = Astro.site?.href ?? 'https://example.com/';
const jsonLd = [
  breadcrumb([
    { name: 'Home', url: base },
    { name: service.short, url: new URL(serviceUrl(service), base).href },
  ]),
  serviceSchema({ name: service.name, description: service.description, areaName: SITE.region }),
  faqPage(service.faqs),
];
const heroUrl = await getHeroUrl();
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} heroImageUrl={heroUrl}>
  <div class="container">
    <nav class="crumbs"><a href="/">Home</a><span>/</span>{service.short}</nav>
  </div>

  <section class="hero hero-single" style={`--hero-img: url(${heroUrl})`}>
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-copy">
        <h1>{service.name} in the {SITE.region}</h1>
        <p class="lede">{service.blurb}</p>
        <div class="hero-cta">
          <a class="btn btn-call btn-lg" href={tel()}>📞 Call {SITE.phoneDisplay}</a>
          <a class="btn btn-dark btn-lg" href="#quote">Get a Free Quote</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container srow">
      <div class="srow-text prose">
        <h2>{service.name}</h2>
        <p>{service.description}</p>
        {service.sections.map((sec) => (
          <Fragment>
            <h2>{sec.h}</h2>
            <p>{sec.body}</p>
          </Fragment>
        ))}
        <ul class="checklist">{service.points.map((p) => <li>{p}</li>)}</ul>
      </div>
      <div class="srow-photo"><Image src={service.image} alt={service.imageAlt} width={800} loading="lazy" style={service.imagePosition ? `object-position: ${service.imagePosition}` : undefined} /></div>
    </div>
  </section>

  {service.hubOnly && (
    <ServiceCards title="Garage Door Services We Provide" sub="Specialized help for every part of your garage door system." />
  )}

  <section class="section section-soft">
    <div class="container" style="max-width:720px;">
      <div id="quote">
        <QuoteForm source={`service:${service.slug}`} heading={`Request ${service.short}`} />
      </div>
    </div>
  </section>

  <FaqSection faqs={service.faqs} title={`${service.name} — FAQs`} />

  <CityLinks
    service={service.hubOnly ? undefined : service}
    title={service.hubOnly ? `Serving the ${SITE.region}` : `${service.short} Across the ${SITE.region}`}
    sub="Choose your city for local service details:"
  />

  <Reviews />
  <FinalCta heading={`Need ${service.short.toLowerCase()}? We can help today.`} />
</BaseLayout>
