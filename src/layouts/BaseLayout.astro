---
import '@fontsource-variable/inter/wght.css'; // self-hosted Inter (no render-blocking 3rd-party request)
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localBusiness } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  /** Extra page-specific JSON-LD (BreadcrumbList, Service, etc.) */
  jsonLd?: object | object[];
  /** Optimized hero image URL — preloaded as the LCP image when provided. */
  heroImageUrl?: string;
}

const { title, description, noindex = false, jsonLd, heroImageUrl } = Astro.props;
const siteBase = Astro.site ?? new URL('https://example.com');
const canonical = new URL(Astro.url.pathname, siteBase).href;
const extra = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const schemas = [localBusiness(siteBase.href), ...extra];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {heroImageUrl && <link rel="preload" as="image" href={heroImageUrl} fetchpriority="high" />}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="theme-color" content="#0f2741" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
