---
import { CITIES } from '../config/cities';
import { cityUrl } from '../lib/urls';

// Two keyless Google Maps embeds — one per county we serve. Querying by county
// keeps each map centered on the right area (a single "East Bay" query drifts to
// San Francisco). No API key required (output=embed renders raster tiles).
const COUNTIES = [
  { name: 'Contra Costa County', query: 'Contra Costa County, California' },
  { name: 'Alameda County', query: 'Alameda County, California' },
];
const embedSrc = (query: string) =>
  `https://www.google.com/maps?q=${encodeURIComponent(query)}&z=10&output=embed`;
---
<section class="section section-soft" id="service-area">
  <div class="container">
    <h2 class="section-title">Our East Bay Service Area</h2>
    <p class="section-sub">Serving Contra Costa and Alameda County homeowners.</p>

    <ul class="cities county-cities">
      {CITIES.map((c) => (
        <li><a href={cityUrl(c)}>📍 {c.name}</a></li>
      ))}
    </ul>

    <div class="county-maps">
      {COUNTIES.map((c) => (
        <figure class="county-map">
          <figcaption>{c.name}</figcaption>
          <div class="area-map">
            <iframe
              title={`Map of ${c.name}`}
              src={embedSrc(c.query)}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .county-maps { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .county-map { margin: 0; }
  .county-map figcaption {
    font-weight: 700; color: var(--navy); font-size: 1.05rem; margin-bottom: 10px;
  }
  .area-map iframe { width: 100%; height: 360px; border: 0; display: block; }
  .county-cities { margin-top: 30px; }

  @media (max-width: 760px) {
    .county-maps { grid-template-columns: 1fr; }
  }
</style>
