---
import { Image } from 'astro:assets';
import basemap from '../assets/maps/service-area.png';
import { CITIES } from '../config/cities';
import { cityUrl } from '../lib/urls';

// Real, supplied basemap (terrain + coverage shape + baked-in city labels) shown
// as an optimized image, with subtle clickable hotspots layered over the city
// dots. No iframe, no map API. `left`/`top` are percentages of the image and are
// calibrated to service-area.png — re-tune them if the basemap is swapped.
interface Pin { name: string; slug: string; left: number; top: number }

const PINS: Pin[] = [
  { name: 'Richmond',     slug: 'richmond',     left: 26, top: 29 },
  { name: 'Concord',      slug: 'concord',      left: 48, top: 21 },
  { name: 'Walnut Creek', slug: 'walnut-creek', left: 57, top: 41 },
  { name: 'Lafayette',    slug: 'lafayette',    left: 43, top: 41 },
  { name: 'Berkeley',     slug: 'berkeley',     left: 29, top: 45 },
  { name: 'Orinda',       slug: 'orinda',       left: 41, top: 50 },
  { name: 'Moraga',       slug: 'moraga',       left: 46, top: 57 },
  { name: 'Oakland',      slug: 'oakland',      left: 27, top: 63 },
  { name: 'Alameda',      slug: 'alameda',      left: 35, top: 71 },
  { name: 'Dublin',       slug: 'dublin',       left: 69, top: 83 },
];

const mapAlt =
  'Map of our East Bay service area across Contra Costa and Alameda County, including Martinez, ' +
  'Concord, Pleasant Hill, Walnut Creek, Lafayette, Orinda, Moraga, Danville, San Ramon and Dublin.';
---
<section class="section section-soft" id="service-area">
  <div class="container">
    <h2 class="section-title">Our East Bay Service Area</h2>
    <p class="section-sub">Serving Contra Costa and Alameda County homeowners.</p>
    <div class="area-grid">
      <div class="area-map">
        <figure class="sa-figure">
          <Image
            class="sa-basemap"
            src={basemap}
            alt={mapAlt}
            widths={[600, 900, 1280, 1536]}
            sizes="(max-width: 920px) 92vw, 58vw"
            format="webp"
            quality={72}
            loading="lazy"
          />
          {PINS.map((p) => (
            <a
              class="sa-hotspot"
              href={cityUrl(p.slug)}
              style={`left:${p.left}%;top:${p.top}%`}
              aria-label={`Garage door repair in ${p.name}`}
            ><span class="sa-hotspot-name">{p.name}</span></a>
          ))}
        </figure>
      </div>
      <ul class="cities area-cities">
        {CITIES.map((c) => (
          <li><a href={cityUrl(c)}>📍 {c.name}</a></li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  /* Light-only to match the rest of the site (no global dark theme). A dark
     variant would need a dark basemap image + site-wide dark mode — see the
     maps/README. */
  .area-map {
    --sa-accent: #16a34a;
    min-height: 0;
    padding: 12px;
    background: #ffffff;
    border-color: var(--line);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sa-figure {
    position: relative;
    margin: 0;
    line-height: 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .sa-basemap {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Invisible-until-hover click target sitting on each city dot. The adjacent
     city list is the equivalent, always-visible way to reach every page. */
  .sa-hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    width: clamp(26px, 5.4%, 46px);
    aspect-ratio: 1;
    border-radius: 50%;
    box-shadow: 0 0 0 2px transparent;
    transition: background 0.15s ease, box-shadow 0.15s ease;
  }
  .sa-hotspot:hover,
  .sa-hotspot:focus-visible {
    background: color-mix(in srgb, var(--sa-accent) 22%, transparent);
    box-shadow: 0 0 0 2px var(--sa-accent), 0 2px 8px rgba(15, 39, 65, 0.25);
    outline: none;
  }
  .sa-hotspot:focus-visible {
    box-shadow: 0 0 0 3px var(--sa-accent);
  }
  /* City name is exposed to assistive tech via aria-label; this keeps the visual
     label (already painted on the map) from being duplicated. */
  .sa-hotspot-name {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .sa-hint {
    margin: 0;
    text-align: center;
    font-size: 0.85rem;
    color: var(--ink-soft);
    line-height: 1.3;
  }

  @media (prefers-reduced-motion: reduce) {
    .sa-hotspot { transition: none; }
  }
</style>
