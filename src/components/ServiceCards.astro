---
import { SERVICES } from '../config/services';
import { serviceUrl, cityServiceUrl } from '../lib/urls';
import type { City } from '../config/cities';

interface Props {
  /** If set, cards link to this service-in-city combo instead of the service hub. */
  city?: City;
  title?: string;
  sub?: string;
}
const { city, title = 'Our Garage Door Services', sub = 'From a snapped spring to a brand-new door, we do it all — fast.' } = Astro.props;
---
<section class="section" id="services">
  <div class="container">
    <h2 class="section-title">{title}</h2>
    <p class="section-sub">{sub}</p>
    <div class="svc-grid">
      {SERVICES.map((s) => (
        <a class="svc-card" href={city ? cityServiceUrl(s, city) : serviceUrl(s)}>
          <h3>{s.name}</h3>
          <p>{s.blurb}</p>
          <span class="more">Learn more →</span>
        </a>
      ))}
    </div>
  </div>
</section>
