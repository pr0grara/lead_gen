---
import { SITE, tel } from '../config/site';

interface Props {
  source?: string;
  heading?: string;
  sub?: string;
}
const {
  source = 'website',
  heading = 'Get a Free Quote',
  sub = "Tell us what's going on — we'll call you right back.",
} = Astro.props;
---
<div class="card">
  <h2>{heading}</h2>
  <p class="card-sub">{sub}</p>
  <form id="lead-form" novalidate data-endpoint={SITE.formEndpoint}>
    {SITE.formAccessKey && <input type="hidden" name="access_key" value={SITE.formAccessKey} />}
    <input type="hidden" name="source" value={source} />
    <input type="hidden" name="subject" value={`New lead — ${SITE.company} (${source})`} />
    {/* Honeypot: bots fill this; humans never see it. */}
    <input type="text" name="company_website" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

    <label for="name" class="lbl">
      <span class="lbl">Name *</span>
      <input type="text" name="name" autocomplete="name" required placeholder="Jane Doe" />
    </label>
    <label for="phone" class="lbl">
      <span class="lbl">Phone</span>
      <input type="tel" name="phone" autocomplete="tel" placeholder="(555) 123-4567" />
    </label>
    <label for="email" class="lbl">
      <span class="lbl">Email *</span>
      <input type="email" name="email" autocomplete="email" required placeholder="jane@email.com" />
    </label>
    <label for="message" class="lbl">
      <span class="lbl">How can we help?</span>
      <textarea name="message" rows="3" placeholder="e.g. broken spring, door won't open…"></textarea>
    </label>

    <button type="submit" class="btn btn-primary btn-lg btn-block">Get My Free Quote</button>
    <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
    <p class="card-sub" style="text-align:center;margin:12px 0 0;font-size:.85rem;">
      or call <a href={tel()} style="color:var(--green-dark);font-weight:700;text-decoration:none;">{SITE.phoneDisplay}</a>
    </p>
  </form>
</div>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function setStatus(msg: string, type: '' | 'error' | 'success') {
    if (!statusEl) return;
    statusEl.textContent = msg;
    statusEl.className = 'form-status' + (type ? ' ' + type : '');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    setStatus('', '');
    const fd = new FormData(form);
    const data = Object.fromEntries(fd.entries()) as Record<string, string>;

    if (data.company_website) return; // honeypot tripped — silently drop
    if (!data.name || !data.name.trim()) return setStatus('Please enter your name.', 'error');
    if (!EMAIL_RE.test((data.email || '').trim()))
      return setStatus('Please enter a valid email address.', 'error');
  
    const endpoint = form.getAttribute('data-endpoint');
    if (!endpoint) {
      return setStatus('Online form isn’t set up yet — please call us instead.', 'error');
    }

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const orig = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Submitting…';
    try {
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: fd,
      });
      if (!res.ok) throw new Error('bad status');
      form.reset();
      setStatus("🎉 Thanks! We've received your request and will call you shortly.", 'success');
    } catch {
      setStatus('Sorry, something went wrong. Please call us instead.', 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = orig;
    }
  });
</script>
